# Copy this file to .env and fill in your keys.

# ===== REQUIRED =====
# Get a FREE key from: https://console.groq.com/keys  (sign up, create API key)
# Groq has a generous free tier — no credit card needed.
GROQ_API_KEY=your_groq_api_key_here

# Wake word runs locally via openWakeWord — no API key needed.

# ===== OPTIONAL =====
# Groq brain model. Defaults to the smartest free-tier model.
# Other options:
#   meta-llama/llama-4-scout-17b-16e-instruct   (Llama 4, multimodal, smart)
#   llama-3.1-8b-instant                         (smallest+fastest, less smart)
GROQ_MODEL=llama-3.3-70b-versatile

# Vision model — must support image input.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Tamil voice (Edge TTS). Options: ta-IN-PallaviNeural (female), ta-IN-ValluvarNeural (male)
TTS_VOICE_TAMIL=ta-IN-ValluvarNeural

# English voice. Try en-US-GuyNeural (male), en-US-AriaNeural (female), en-GB-RyanNeural (British male)
TTS_VOICE_ENGLISH=en-US-GuyNeural

# Whisper model size. tiny / base / small / medium / large-v3
# tiny = fast (~0.3s, less accurate); small = balanced; large-v3 = best Tamil (~3GB)
WHISPER_MODEL=small

# How long to listen after wake word (seconds before auto-stop on silence)
MAX_LISTEN_SECONDS=15

# After Jarvis replies, listen this many seconds for a follow-up command (no re-wake).
# Set to 0 to disable follow-up mode.
FOLLOWUP_SECONDS=8
