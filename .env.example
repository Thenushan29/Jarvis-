# Copy this file to .env and fill in YOUR provider + API key.
# Jarvis works with any LLM provider — pick one below.

# ===== STEP 1: PICK YOUR LLM PROVIDER =====
# Supported: groq | openai | anthropic | gemini | openrouter | ollama | together | openai_compat
LLM_PROVIDER=groq

# ===== STEP 2: PASTE YOUR API KEY =====
# Get one from your provider's dashboard. Free options:
#   groq    -> https://console.groq.com/keys              (free tier, fast)
#   gemini  -> https://aistudio.google.com/app/apikey     (free tier)
#   ollama  -> no key, runs locally (just set LLM_API_KEY=ollama)
# Paid:
#   openai     -> https://platform.openai.com/api-keys
#   anthropic  -> https://console.anthropic.com/
#   openrouter -> https://openrouter.ai/keys              (paid, many models)
#   together   -> https://api.together.xyz/settings/api-keys
LLM_API_KEY=your_api_key_here

# ===== STEP 3: (OPTIONAL) MODEL OVERRIDES =====
# Defaults are sensible per provider. Override only if you want a different model.
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=                                            # only for custom OpenAI-compat endpoints

# ===== STEP 4: (OPTIONAL) DIFFERENT VISION PROVIDER =====
# Vision uses the same provider/key by default. To use a different one for screen reading:
# VISION_PROVIDER=groq
# VISION_API_KEY=
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# VISION_BASE_URL=

# ===== STEP 5: (OPTIONAL) VOICES =====
# Tamil voice. Options: ta-IN-PallaviNeural (female), ta-IN-ValluvarNeural (male)
TTS_VOICE_TAMIL=ta-IN-ValluvarNeural

# English voice. Try en-US-GuyNeural / en-US-AriaNeural / en-IN-PrabhatNeural
TTS_VOICE_ENGLISH=en-US-GuyNeural

# Whisper model. tiny = fast (~0.3s), small = balanced, large-v3 = best Tamil (~3GB)
WHISPER_MODEL=tiny

# Max listen time after wake word
MAX_LISTEN_SECONDS=15

# Seconds of follow-up listening after a reply (no re-wake). 0 to disable.
FOLLOWUP_SECONDS=8


# ===== QUICK PROVIDER RECIPES =====
#
# Groq (free, fast):
#   LLM_PROVIDER=groq
#   LLM_API_KEY=gsk_...
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-proj-...
#   LLM_MODEL=gpt-4o-mini
#
# Anthropic Claude:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-6
#
# Google Gemini:
#   LLM_PROVIDER=gemini
#   LLM_API_KEY=AIza...
#   LLM_MODEL=gemini-2.5-flash
#
# Local Ollama (no key, no internet needed):
#   LLM_PROVIDER=ollama
#   LLM_API_KEY=ollama
#   LLM_MODEL=llama3.3
#
# OpenRouter (one key, hundreds of models):
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-v1-...
#   LLM_MODEL=anthropic/claude-sonnet-4
